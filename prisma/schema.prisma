// Prisma schema for Netline

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Graph {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  nodes     Node[]
}

model Node {
  id          String   @id                    // e.g. "A-fw01"
  graphId     Int
  hostname    String
  system      String
  type        String                          // "fw" | "router" | "switch" | "server" | "workstation" | "client" | "iot" | "unknown"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  graph       Graph    @relation(fields: [graphId], references: [id], onDelete: Cascade)
  ips         NodeIp[]
  linksFrom   Link[]   @relation("LinkSource")
  linksTo     Link[]   @relation("LinkTarget")
  note        Note?
  events      Event[]

  @@index([graphId])
}

model NodeIp {
  id       Int    @id @default(autoincrement())
  nodeId   String
  address  String
  subnet   String @default("")

  node     Node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId])
}

model Link {
  id       Int    @id @default(autoincrement())
  source   String
  target   String
  label    String @default("")

  sourceNode Node  @relation("LinkSource", fields: [source], references: [id], onDelete: Cascade)
  targetNode Node  @relation("LinkTarget", fields: [target], references: [id], onDelete: Cascade)

  @@unique([source, target])
}

model Note {
  nodeId    String   @id
  content   String   @db.Text
  updatedAt DateTime @updatedAt

  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

model Event {
  id          Int      @id @default(autoincrement())
  nodeId      String
  datetime    DateTime
  description String   @db.Text
  actor       String                          // "blue" | "red" | "grey"
  severity    String   @default("none")
  mitre       String   @default("")
  tool        String   @default("")
  cve         String   @default("")
  srcIp       String   @default("")
  dstIp       String   @default("")
  createdAt   DateTime @default(now())

  node        Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId])
  @@index([datetime])
}
