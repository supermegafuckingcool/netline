# ── Netline environment variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your values before running ./start.sh
# All variables have safe defaults for local use — change passwords for any
# internet-facing deployment.

# ── Database ──────────────────────────────────────────────────────────────────

# MySQL root password (used for initial DB setup only, not by the app)
MYSQL_ROOT_PASSWORD=changeme_root

# MySQL password for the netline application user
MYSQL_PASSWORD=changeme_netline

# ── Application ───────────────────────────────────────────────────────────────

# Port the app listens on (host-side)
PORT=3000

# ── Notes ─────────────────────────────────────────────────────────────────────
# DATABASE_URL is constructed automatically from MYSQL_PASSWORD inside
# docker-compose.yml — do not set it here unless you are overriding the
# connection string entirely.
#
# Prisma does not use NODE_ENV directly, but setting it to "production"
# disables some development-only features and improves error messaging.
# NODE_ENV=production  (set automatically in docker-compose.yml)
