# Copy this file to .env and fill in your values
# The defaults work for local development

# MySQL root password (only used internally by the db container)
MYSQL_ROOT_PASSWORD=rootpassword

# MySQL password for the netline user
MYSQL_PASSWORD=netlinepassword

# Port to expose the app on the host machine
PORT=3000

# Prisma database URL — constructed automatically in docker-compose
# Only set this manually if running outside Docker
# DATABASE_URL=mysql://netline:netlinepassword@localhost:3306/netline
